{
  "name": "@decent-render/protocol",
  "version": "0.1.0",
  "description": "Decent render-network wire protocol (v2) — shared TS types + zod schemas. Canonical to the Rust supervisor-core; pinned by a cross-language conformance test.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^3.23.8"
  },
  "keywords": [
    "decent-render",
    "render-farm",
    "protocol",
    "wire-protocol",
    "remotion"
  ]
}
